{
  "name": "vscode-ext",
  "displayName": "Qunoqu",
  "version": "0.0.0",
  "description": "Qunoqu – developer memory for AI. Capture, recall, and save decisions from the editor.",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qunoqu.recall",
        "title": "Qunoqu: Recall (search memories)"
      },
      {
        "command": "qunoqu.saveDecision",
        "title": "Qunoqu: Save decision"
      }
    ],
    "configuration": {}
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qunoqu/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0 <5.6.0",
    "vitest": "^1.3.0"
  }
}
