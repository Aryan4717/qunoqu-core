{
  "name": "vscode-ext",
  "displayName": "Qunoqu",
  "version": "0.0.0",
  "description": "Qunoqu VS Code extension",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "qunoqu.hello",
        "title": "Qunoqu: Hello"
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qunoqu/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
