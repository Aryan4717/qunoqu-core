{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "noEmit": false,
    "composite": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", "**/*.test.ts", "**/*.spec.ts"]
}
